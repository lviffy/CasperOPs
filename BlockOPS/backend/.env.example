# Arbitrum Sepolia Configuration
PORT=3000

# Agent Backend URL (Python FastAPI service for tool execution)
AGENT_BACKEND_URL=http://localhost:8000

# ERC-8004 Registry Addresses on Arbitrum Sepolia
# Deploy via contract/erc8004-registries and update here
IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REPUTATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VALIDATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Stylus Contract Addresses on Arbitrum Sepolia
# Deploy your Stylus contracts and add the addresses here
TOKEN_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NFT_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: OpenAI API Key for future AI features
OPENAI_API_KEY=

# Groq API Key (Primary for AI features)
# Multiple keys for automatic fallback on rate limits (429 errors)
GROQ_API_KEY1=
GROQ_API_KEY2=
GROQ_API_KEY3=

# Google Gemini API Key for AI-powered token price fetching (Fallback)
GEMINI_API_KEY=

# Etherscan API Key for contract ABI fetching (Natural Language Executor)
ETHERSCAN_API_KEY=

# Optional: Pinata for IPFS (if you want to add IPFS support later)
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Filecoin Calibration (Synapse SDK only) for immutable audit storage
# Required wallet key for signing prepare() transactions on Calibration testnet.
# Accepts either 64-char hex or 0x-prefixed 64-char hex.
FILECOIN_WALLET_PRIVATE_KEY=

# Source label written in Synapse metadata to identify this app.
SYNAPSE_SOURCE=blockops-agent-audit

# Optional: enable Filecoin Beam retrieval acceleration.
SYNAPSE_WITH_CDN=false

# Optional: extra prepare() data-size buffer to avoid lockup edge-case shortfalls.
FILECOIN_PREPARE_BUFFER_BYTES=4096

# Optional: max milliseconds the chat API waits for Filecoin archival before responding.
# If exceeded, response returns with storageStatus=pending and archival continues in background.
FILECOIN_AUDIT_WAIT_MS=8000

# Supabase Configuration (for conversation memory)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Admin secret for cleanup endpoints (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SECRET=your_random_32_char_admin_secret_here
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_API_KEY=REPLACE_ME_WITH_A_RANDOM_SECRET  
# Optional backend signer used for agent registration when the request does not provide a user private key
SERVER_SIGNER_PRIVATE_KEY=
# Gmail Configuration (for email tool via nodemailer)
# Generate an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Telegram Bot Configuration
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Webhook URL (production only — omit for local long-polling dev mode)
TELEGRAM_WEBHOOK_URL=https://blockops.in

# Lit Protocol Configuration (required when users.private_key stores lit:v1 payloads)
# Telegram linked-agent chats resolve the same user key context as website chat via users.private_key/users.wallet_address.
LIT_API_BASE_URL=https://api.dev.litprotocol.com/core/v1
LIT_USAGE_API_KEY=
# Optional fallback PKP ID (payload pkpId is used first)
LIT_PKP_ID=

# Bridge — Ethereum Sepolia RPC (for L1↔L2 bridge deposits)
# Defaults to public RPCs if not set
ETHEREUM_SEPOLIA_RPC=https://rpc.sepolia.org

# Uniswap V3 on Arbitrum Sepolia (defaults are pre-filled in swapController)
# Override only if using a custom deployment
# UNISWAP_V3_ROUTER=0x101F443B4d1b059569D643917553c771E1b9663E
# UNISWAP_V3_QUOTER=0x2D99ABB6958e6F060f4F36b3d5e77fEBa35c8e2D
# WETH_ADDRESS=0x980B62Da83eFf3D4576C647993b0c1D7faf17c73
