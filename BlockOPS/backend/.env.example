# =============================================================================
# BlockOps Backend Environment Configuration — Casper Network only
# =============================================================================
# After cloning, copy this file to `.env` and fill in real secrets.
# =============================================================================

# HTTP server
PORT=3000

# -----------------------------------------------------------------------------
# Casper Network (Testnet)
# -----------------------------------------------------------------------------
# Public RPC endpoint. The default works out of the box.
CASPER_RPC_URL=https://rpc.testnet.casper.live/rpc

# CSPR.cloud (faster indexing for balances, tokens, NFTs, deploys)
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
# Optional: bearer token from https://cspr.cloud (increases rate limits)
CSPR_CLOUD_API_KEY=

# Testnet chain name used in every deploy
CASPER_CHAIN_NAME=casper-test

# Server-side signer (used by tools that submit on-chain deploys from the
# backend: register_agent, attest_agent, get_reputation).
# 64-char hex (no 0x prefix), or 0x + 64 chars.
CASPER_SECRET_KEY=

# Deployed Odra contract hashes — fill these in after running
#   cd contract && node scripts/deploy.js
CASPER_AGENT_FACTORY_HASH=
CASPER_REPUTATION_HASH=
CASPER_ESCROW_HASH=
CASPER_COMPLIANCE_HASH=

# -----------------------------------------------------------------------------
# AI Providers (at least one is required for natural-language tool routing)
# -----------------------------------------------------------------------------
# Groq is the primary driver of `intelligentToolRouting`. Multiple keys enable
# automatic fallback on 429 rate-limit responses.
GROQ_API_KEY1=
GROQ_API_KEY2=
GROQ_API_KEY3=

# Optional: Google Gemini for fallback / token-price fetches
GEMINI_API_KEY=

# Optional: OpenAI (reserved for future features)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Supabase (conversation memory, agent marketplace, user accounts)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=replace_me
MASTER_API_KEY=replace_me

# Optional fallback signer used when a user request lacks a private key
SERVER_SIGNER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# Gmail (App Password: https://myaccount.google.com/apppasswords)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Telegram (BotFather token)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://blockops.in

# -----------------------------------------------------------------------------
# Agent backend (optional — LangGraph / CrewAI executor in n8n_agent_backend/)
# -----------------------------------------------------------------------------
AGENT_BACKEND_URL=http://localhost:8000

# =============================================================================
# DEPRECATED — EVM / Flow / Filecoin / Lit PKP keys have been removed.
# BlockOps now ships with Casper-only tools (CSPR transfers, CEP-18 / CEP-78
# deploys, on-chain agent registry). The legacy services
#   backend/services/litPkpService.js
#   backend/services/filecoinStorageService.js
# are kept only for backwards compatibility with stored encrypted keys; they
# will be removed in a future release. Do not configure them in `.env`.
# =============================================================================
