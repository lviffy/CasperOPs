# AI Provider Configuration
# At least one of GROQ_API_KEY or GEMINI_API_KEY must be set

# Primary: Groq API Key (uses llama-3.3-70b-versatile)
# Multiple keys for automatic fallback on rate limits (429 errors)
GROQ_API_KEY1=your_groq_api_key_here
GROQ_API_KEY2=your_groq_api_key_here
GROQ_API_KEY3=your_groq_api_key_here

# Fallback: Google Gemini API Key (uses gemini-2.0-flash)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Backend URL (defaults to http://localhost:3000)
BACKEND_URL=http://localhost:3000

# Optional: Phase 26 metrics endpoint auth. When set, /metrics requires
# `Authorization: Bearer <token>` or `X-Metrics-Token: <token>`.
METRICS_TOKEN=
