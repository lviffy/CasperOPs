{
  "name": "casperops-backend",
  "version": "1.0.0",
  "description": "Backend API for CasperOPs Casper Network integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test.js",
    "test:unit": "REDIS_URL=\"\" METRICS_DISABLED=true node --test --test-isolation=process --test-concurrency=1 __tests__/*.test.js",
    "coverage": "REDIS_URL=\"\" METRICS_DISABLED=true c8 --reporter=text --reporter=html --reporter=json-summary node --test --test-isolation=process --test-concurrency=1 __tests__/*.test.js"
  },
  "keywords": [
    "casper",
    "blockchain",
    "odra",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@sentry/node": "^10.59.0",
    "@supabase/supabase-js": "^2.95.3",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "casper-js-sdk": "^2.15.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "form-data": "^4.0.0",
    "groq-sdk": "^0.37.0",
    "ioredis": "^5.11.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "openai": "^4.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "stripe": "^22.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "c8": "^10.1.2",
    "chai": "^4.5.0",
    "nodemon": "^3.0.1",
    "sinon": "^17.0.1"
  }
}
